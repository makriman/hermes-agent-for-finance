# Copy the relevant lines into ~/.hermes/.env and fill in real values.
# NEVER commit the real .env — it is git-ignored for a reason.

# ── Model provider ───────────────────────────────────────────────────────────
# This build used Claude Sonnet via the GitHub Copilot CLI (`gh copilot`), which
# authenticates through the gh CLI — no API key here. Configure your own provider
# per hermes-agent docs if you use a different one.

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_USERS=123456789            # comma-separated numeric user ids

# ── WhatsApp Cloud API (Meta) ────────────────────────────────────────────────
WHATSAPP_CLOUD_ENABLED=true
WA_ACCESS_TOKEN=your-permanent-system-user-token
WA_PHONE_NUMBER_ID=your-phone-number-id
WA_APP_SECRET=your-app-secret               # verifies the X-Hub-Signature-256 webhook HMAC
WA_VERIFY_TOKEN=any-random-string           # must match the token you set in the Meta webhook UI
WA_GRAPH_VERSION=v21.0
WHATSAPP_CLOUD_HOST=127.0.0.1               # bind local; put a tunnel in front
WHATSAPP_CLOUD_PORT=8085
WHATSAPP_CLOUD_ALLOWED_USERS=447700900000   # comma-separated wa_ids (E.164, no +)
WHATSAPP_CLOUD_MAX_MEDIA_MB=25              # inbound/outbound media cap (RAM guard)

# ── Speech-to-text (optional cloud offload; default is local faster-whisper) ──
# GROQ_API_KEY=your-groq-key

# ── Observability: Langfuse (optional) ───────────────────────────────────────
# HERMES_LANGFUSE_PUBLIC_KEY=pk-lf-...
# HERMES_LANGFUSE_SECRET_KEY=sk-lf-...
# HERMES_LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_HOST=https://cloud.langfuse.com
