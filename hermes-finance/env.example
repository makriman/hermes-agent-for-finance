# Copy the relevant lines into ~/.hermes/.env and fill in real values.
# NEVER commit the real .env — it is git-ignored for a reason.
#
# WhatsApp Cloud and Telegram are BUILT IN to hermes-agent (>= v0.18) — you do
# not need any custom adapter code. Setting these env vars enables them.

# ── Model provider ───────────────────────────────────────────────────────────
# This build uses Claude Sonnet via the GitHub Copilot CLI (`gh copilot`), which
# authenticates through the gh CLI — no API key here. In config.yaml:
#   model: { default: copilot/claude-sonnet-4.6, provider: copilot }

# ── Telegram (native platform) ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_USERS=123456789            # comma-separated numeric user ids

# ── WhatsApp Cloud API (native platform, Meta) ───────────────────────────────
# Presence of ACCESS_TOKEN + PHONE_NUMBER_ID is what enables the platform.
WHATSAPP_CLOUD_ACCESS_TOKEN=your-permanent-system-user-token
WHATSAPP_CLOUD_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_CLOUD_APP_SECRET=your-app-secret          # verifies the webhook HMAC (X-Hub-Signature-256)
WHATSAPP_CLOUD_VERIFY_TOKEN=any-random-string      # must match the token set in the Meta webhook UI
WHATSAPP_CLOUD_API_VERSION=v21.0
WHATSAPP_CLOUD_WEBHOOK_HOST=127.0.0.1              # bind local; put a tunnel in front
WHATSAPP_CLOUD_WEBHOOK_PORT=8085
WHATSAPP_CLOUD_WEBHOOK_PATH=/wa/webhook            # point your Meta webhook + tunnel here
WHATSAPP_CLOUD_ALLOWED_USERS=447700900000          # comma-separated wa_ids (E.164, no +)

# ── Speech-to-text (optional cloud offload; default is local faster-whisper) ──
# GROQ_API_KEY=your-groq-key

# ── Observability: Langfuse (optional) ───────────────────────────────────────
# HERMES_LANGFUSE_PUBLIC_KEY=pk-lf-...
# HERMES_LANGFUSE_SECRET_KEY=sk-lf-...
# HERMES_LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_HOST=https://cloud.langfuse.com
