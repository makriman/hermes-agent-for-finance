# Active org (any of the 9 slugs). See `GET /sim/orgs`.
CASHEW_ORG=jam-scn-1

# Forecast anchor (end of month) and the month being forecast.
CASHEW_ANCHOR=2026-06-30
CASHEW_SCENARIO_MONTH=2026-07

# Deterministic synthesis (AR/AP dates, payment lateness). Same seed => same data.
CASHEW_SEED=42

# --- Alternate config: a denser FULL month for rich daily reconciliation -----
# The July scenario month is intentionally front-loaded (shocks on the 1st).
# For a busy month-long reconcile demo, anchor on an earlier full month:
# CASHEW_ANCHOR=2026-04-30
# CASHEW_SCENARIO_MONTH=2026-05
