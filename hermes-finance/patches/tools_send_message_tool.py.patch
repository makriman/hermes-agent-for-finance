+async def _send_whatsapp_cloud(chat_id, message, media_files=None, force_document=False):
+    """Deliver text + native media via the running whatsapp_cloud adapter —
+    images, video, audio/voice notes, and documents (e.g. the Excel export).
+    Mirrors the Yuanbao/Feishu helpers: grab the live adapter from the running
+    gateway and call its send_* methods (which upload to WhatsApp /media)."""
+    try:
+        from gateway.run import _gateway_runner_ref
+        from gateway.config import Platform
+        runner = _gateway_runner_ref()
+    except Exception:
+        runner = None
+    adapter = runner.adapters.get(Platform.WHATSAPP_CLOUD) if runner is not None else None
+    if adapter is None:
+        return _error("WhatsApp Cloud adapter is not running. "
+                      "Start the gateway with whatsapp_cloud enabled first.")
+
+    # WhatsApp accepts these as native audio messages (Telegram's _VOICE_EXTS is
+    # ogg/opus-only; TTS here emits .mp3, so widen to WhatsApp's audio set).
+    _WA_AUDIO = {".ogg", ".opus", ".mp3", ".m4a", ".aac", ".amr"}
+
+    # Text first (adapter.send chunks it), then each attachment natively.
+    if message and message.strip():
+        tr = await adapter.send(chat_id=chat_id, content=message)
+        if not getattr(tr, "success", False):
+            return _error(f"WhatsApp text send failed: {getattr(tr, 'error', 'unknown')}")
+
+    last = None
+    for media_path, is_voice in (media_files or []):
+        if not os.path.exists(media_path):
+            continue
+        ext = os.path.splitext(media_path)[1].lower()
+        if not force_document and ext in _IMAGE_EXTS:
+            last = await adapter.send_image(chat_id, media_path)
+        elif ext in _VIDEO_EXTS:
+            last = await adapter.send_video(chat_id, media_path)
+        elif not force_document and ext in _WA_AUDIO:
+            last = await adapter.send_voice(chat_id, media_path)
+        else:
+            last = await adapter.send_document(chat_id, media_path)
+        if last is not None and not getattr(last, "success", True):
+            return _error(f"WhatsApp media send failed: {getattr(last, 'error', 'unknown')}")
+
+    return {"success": True,
+            "message_id": getattr(last, "message_id", None) if last is not None else None}
+
+
