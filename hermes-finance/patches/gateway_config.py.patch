diff --git a/gateway/config.py b/gateway/config.py
index 6f30ee706..1084690fb 100644
--- a/gateway/config.py
+++ b/gateway/config.py
@@ -109,6 +109,7 @@ class Platform(Enum):
     TELEGRAM = "telegram"
     DISCORD = "discord"
     WHATSAPP = "whatsapp"
+    WHATSAPP_CLOUD = "whatsapp_cloud"
     SLACK = "slack"
     SIGNAL = "signal"
     MATTERMOST = "mattermost"
@@ -419,6 +420,8 @@ _PLATFORM_CONNECTED_CHECKERS: dict[Platform, Callable[[PlatformConfig], bool]] =
         cfg.extra.get("account_id") and (cfg.token or cfg.extra.get("token"))
     ),
     Platform.WHATSAPP: lambda cfg: True,  # bridge handles auth
+    Platform.WHATSAPP_CLOUD: lambda cfg: bool(
+        cfg.token and cfg.extra.get("phone_number_id")),
     Platform.SIGNAL: lambda cfg: bool(cfg.extra.get("http_url")),
     Platform.EMAIL: lambda cfg: bool(cfg.extra.get("address")),
     Platform.SMS: lambda cfg: bool(os.getenv("TWILIO_ACCOUNT_SID")),
@@ -1466,6 +1469,28 @@ def _apply_env_overrides(config: GatewayConfig) -> None:
         if api_server_model_name:
             config.platforms[Platform.API_SERVER].extra["model_name"] = api_server_model_name
 
+    # WhatsApp Cloud API (native adapter — official Meta Cloud API, NOT Baileys)
+    wac_enabled = os.getenv("WHATSAPP_CLOUD_ENABLED", "").lower() in {"true", "1", "yes"}
+    wac_token = os.getenv("WA_ACCESS_TOKEN", "")
+    wac_phone_id = os.getenv("WA_PHONE_NUMBER_ID", "")
+    if wac_enabled or (wac_token and wac_phone_id):
+        if Platform.WHATSAPP_CLOUD not in config.platforms:
+            config.platforms[Platform.WHATSAPP_CLOUD] = PlatformConfig()
+        pc = config.platforms[Platform.WHATSAPP_CLOUD]
+        pc.enabled = True
+        pc.token = wac_token
+        pc.extra["phone_number_id"] = wac_phone_id
+        pc.extra["app_secret"] = os.getenv("WA_APP_SECRET", "")
+        pc.extra["verify_token"] = os.getenv("WA_VERIFY_TOKEN", "")
+        pc.extra["graph_version"] = os.getenv("WA_GRAPH_VERSION", "v21.0")
+        if os.getenv("WHATSAPP_CLOUD_PORT"):
+            try:
+                pc.extra["port"] = int(os.getenv("WHATSAPP_CLOUD_PORT"))
+            except ValueError:
+                pass
+        if os.getenv("WHATSAPP_CLOUD_HOST"):
+            pc.extra["host"] = os.getenv("WHATSAPP_CLOUD_HOST")
+
     # Webhook platform
     webhook_enabled = os.getenv("WEBHOOK_ENABLED", "").lower() in {"true", "1", "yes"}
     webhook_port = os.getenv("WEBHOOK_PORT")
